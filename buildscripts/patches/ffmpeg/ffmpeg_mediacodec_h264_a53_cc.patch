     if (ret != AVERROR(EAGAIN))
         return ret;
 
@@ -512,7 +966,7 @@ static int mediacodec_receive_frame(AVCodecContext *avctx, AVFrame *frame)
             index = ff_AMediaCodec_dequeueInputBuffer(s->ctx->codec, 0);
             if (index < 0) {
