+extern "C" __attribute__ ((visibility ("default"))) void MediaKitAndroidHelperEmitCc608Text(const char* text) {
+    if (g_jvm == NULL) {
+        __android_log_print(ANDROID_LOG_DEBUG, "media_kit", "MediaKitAndroidHelperEmitCc608Text: g_jvm == NULL");
+        return;
+    }
+
+    JNIEnv* env = NULL;
+    bool attached = false;
+
+    jint get_env_result = g_jvm->GetEnv((void**)&env, JNI_VERSION_1_6);
+    if (get_env_result != JNI_OK) {
+        if (g_jvm->AttachCurrentThread(&env, NULL) == JNI_OK) {
+            attached = true;
+        } else {
+            __android_log_print(ANDROID_LOG_DEBUG, "media_kit", "MediaKitAndroidHelperEmitCc608Text: AttachCurrentThread failed");
+            return;
+        }
+    }
+
+    jclass cls = env->FindClass("com/tvezplayer/cc608_bridge/Cc608BridgePlugin");
+    if (cls == NULL) {
+        __android_log_print(ANDROID_LOG_DEBUG, "media_kit", "MediaKitAndroidHelperEmitCc608Text: MPVLib class not found");
+        if (attached) g_jvm->DetachCurrentThread();
+        return;
+    }
+
+    jmethodID mid = env->GetStaticMethodID(
+        cls,
+        "emit",
+        "(Ljava/lang/String;)V"
+    );
+    if (mid == NULL) {
+        __android_log_print(ANDROID_LOG_DEBUG, "media_kit", "MediaKitAndroidHelperEmitCc608Text: eventProperty(String,String) not found");
+        if (attached) g_jvm->DetachCurrentThread();
+        return;
+    }
+
+    jstring value = env->NewStringUTF(text ? text : "");
+    env->CallStaticVoidMethod(cls, mid, value);    
+
+
+    env->DeleteLocalRef(value);
+    env->DeleteLocalRef(cls);
+
+    if (attached) {
+        g_jvm->DetachCurrentThread();
+    }
+}
